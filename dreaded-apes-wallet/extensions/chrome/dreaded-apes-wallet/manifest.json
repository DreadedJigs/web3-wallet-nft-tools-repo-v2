{
  "manifest_version": 3,
  "name": "Dreaded Apes Wallet",
  "version": "1.0.0",
  "description": "A multichain media vault and Dreaded Guard transaction review layer.",
  "action": {
    "default_title": "Dreaded Apes Wallet",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "assets/core/dreaded-apes-app-icon-512.png"
    }
  },
  "icons": {
    "128": "assets/core/dreaded-apes-app-icon-512.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*/*"
  ]
}
