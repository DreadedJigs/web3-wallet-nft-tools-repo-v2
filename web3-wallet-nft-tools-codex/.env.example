# Frontend public config
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_DEFAULT_CHAIN=sepolia
NEXT_PUBLIC_APP_NAME="Web3 Wallet NFT Tools"

# RPC URLs for scripts/deployments. Do not expose server/private RPC keys in client code.
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
POLYGON_AMOY_RPC_URL=

# Deployment-only secrets. Never commit real values.
PRIVATE_KEY=
ETHERSCAN_API_KEY=

# Optional NFT pinning provider token. Never expose in browser code.
PINATA_JWT=
